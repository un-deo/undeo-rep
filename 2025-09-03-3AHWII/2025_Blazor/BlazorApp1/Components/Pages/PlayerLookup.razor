@page "/player"
@rendermode InteractiveServer

@using System.Net.Http.Json
@inject HttpClient Http

<PageTitle>Player Lookup</PageTitle>

<h1>Player Lookup</h1>

<div class="mb-3 row">
    <div class="col-sm-3">
        <select class="form-select" @bind="platform">
            <option value="minecraft">minecraft</option>
            <option value="steam">steam</option>
            <option value="xbox">xbox</option>
            <!-- PSN removed: playerdb.co does not reliably support PSN lookups -->
        </select>
    </div>
    <div class="col-sm-5">
        <input class="form-control"
               placeholder="@((platform == "steam") ? "Steam ID" : "username")"
               @bind:event="oninput"
               @bind="username"
               @onkeydown="OnKeyDown" />
    </div>
    <div class="col-sm-2">
        <button class="btn btn-primary" @onclick="Lookup">Lookup</button>
    </div>
</div>

@if (loading)
{
    <p><em>Loading...</em></p>
}
else if (error != null)
{
    <div class="alert alert-danger">@error</div>
}
else if (player != null)
{
    <div class="card" style="max-width: 540px;">
        <div class="row g-0">
            <div class="col-md-4">
                @if (!string.IsNullOrEmpty(player.Avatar))
                {
                    <img src="@player.Avatar" class="img-fluid rounded-start" alt="avatar" />
                }
            </div>
            <div class="col-md-8">
                <div class="card-body">
                    <h5 class="card-title">@player.Username</h5>
                    <p class="card-text"><small class="text-muted">ID: @player.Id</small></p>
                    @if (player.Meta?.Any() == true)
                    {
                        <ul>
                            @foreach (var kv in player.Meta)
                            {
                                <li><strong>@kv.Key:</strong> @kv.Value</li>
                            }
                        </ul>
                    }
                </div>
            </div>
        </div>
    </div>
}

@code {
    string platform = "minecraft";
    string username = "";
    bool loading = false;
    string? error;

    Player? player;

    async Task Lookup()
    {
        error = null;
        player = null;
        if (string.IsNullOrWhiteSpace(username))
        {
            error = "Please enter a username.";
            return;
        }

        loading = true;
        try
        {
            var url = $"https://playerdb.co/api/player/{platform}/{Uri.EscapeDataString(username)}";
            // PlayerDB recommends an identifying User-Agent. Use HttpRequestMessage so we can set headers and inspect status codes.
            using var req = new HttpRequestMessage(HttpMethod.Get, url);
            req.Headers.UserAgent.ParseAdd("BlazorApp1/1.0 (+https://example.com; contact: you@example.com)");

            using var respMsg = await Http.SendAsync(req);
            if (!respMsg.IsSuccessStatusCode)
            {
                error = $"API returned {(int)respMsg.StatusCode} {respMsg.ReasonPhrase}";
            }
            else
            {
                var resp = await respMsg.Content.ReadFromJsonAsync<PlayerDbResponse>();
                if (resp == null || !resp.Success || resp.Data?.Player == null)
                {
                    error = "Player not found or API error.";
                }
                else
                {
                    player = new Player
                    {
                        Id = resp.Data.Player.Id,
                        Username = resp.Data.Player.Username,
                        Avatar = resp.Data.Player.Avatar,
                        Meta = resp.Data.Player.Meta
                    };
                }
            }
        }
        catch (Exception ex)
        {
            error = ex.Message;
        }
        finally
        {
            loading = false;
        }
    }

    async Task OnKeyDown(KeyboardEventArgs e)
    {
        // Trigger lookup when Enter is pressed
        if (e.Key == "Enter")
        {
            await Lookup();
        }
    }

    // Minimal DTOs for the response
    class PlayerDbResponse
    {
        public bool Success { get; set; }
        public PlayerData? Data { get; set; }
    }

    class PlayerData
    {
        public InnerPlayer? Player { get; set; }
    }

    class InnerPlayer
    {
        public string? Id { get; set; }
        public string? Username { get; set; }
        public string? Avatar { get; set; }
        public Dictionary<string, object>? Meta { get; set; }
    }

    class Player
    {
        public string? Id { get; set; }
        public string? Username { get; set; }
        public string? Avatar { get; set; }
        public Dictionary<string, object>? Meta { get; set; }
    }
}
